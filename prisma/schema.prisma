// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User ────────────────────────────────────────────────────────────────────
// Stores login credentials for dashboard users.
model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  servers ScreepsServer[]
}

// ─── Screeps Server ──────────────────────────────────────────────────────────
// Represents a Screeps server instance (e.g. "World", "Season 8").
model ScreepsServer {
  id             String   @id @default(uuid())
  name           String   // e.g. "World", "Season 8"
  apiToken       String?  // Screeps API token / key for this server
  pushToken      String   @unique @default(uuid()) // Static token for push endpoints
  apiBaseUrl     String   @default("https://screeps.com") // Base URL for the Screeps API
  shard          String   @default("shard3") // Which shard to poll
  pollingEnabled Boolean  @default(false) // Whether background polling is enabled
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  stats                 TickSnapshot[]
  logs                  Log[]
  flightRecorderEntries FlightRecorderEntry[]

  @@index([userId])
}

// ─── TickSnapshot ────────────────────────────────────────────────────────────
// Per-tick stats snapshot from StatsExporter (segment 97 or Memory.stats).
// Typed columns replace the old JSON blob approach for efficient storage and querying.
model TickSnapshot {
  id         Int      @id @default(autoincrement())
  tick       Int
  shard      String   @default("shard3")
  recordedAt DateTime @default(now())

  serverId String
  server   ScreepsServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  // ── CPU ──
  cpuUsed      Float @default(0)
  cpuLimit     Int   @default(0)
  cpuBucket    Int   @default(0)
  cpuTickLimit Int   @default(0)

  // ── GCL / GPL ──
  gclLevel         Int   @default(0)
  gclProgress      Float @default(0)
  gclProgressTotal Float @default(0)
  gplLevel         Int   @default(0)
  gplProgress      Float @default(0)
  gplProgressTotal Float @default(0)

  // ── Heap ──
  heapUsed  BigInt @default(0)
  heapLimit BigInt @default(0)
  heapRatio Float  @default(0)

  // ── Market ──
  marketCredits      Int @default(0)
  marketActiveOrders Int @default(0)

  // ── Creeps ──
  creepsMy      Int @default(0)
  creepsHostile Int @default(0)

  // ── Spawns ──
  spawnsTotal       Int   @default(0)
  spawnsActive      Int   @default(0)
  spawnsUtilization Float @default(0)

  // ── Defense ──
  defenseTowerCount     Int    @default(0)
  defenseTowerEnergy    Int    @default(0)
  defenseRampartCount   Int    @default(0)
  defenseRampartMinHits BigInt @default(0)

  // ── ErrorMapper ──
  errorMapperTotalErrors      Int   @default(0)
  errorMapperMappedCount      Int   @default(0)
  errorMapperRawCount         Int   @default(0)
  errorMapperCpuUsed          Float @default(0)
  errorMapperUniqueFingerprints Int  @default(0)
  errorMapperDeferredQueue    Int   @default(0)
  errorMapperInResetLoop      Int   @default(0)

  // ── Cache ──
  cacheSize            Int   @default(0)
  cacheDirtyCount      Int   @default(0)
  cachePathCacheSize   Int   @default(0)
  cacheHeapRatio       Float @default(0)
  cacheEvictedThisTick Int   @default(0)
  cacheCommitCPU       Float @default(0)
  cacheSchemaVersion   Int   @default(0)
  cacheBucketThrottled Int   @default(0)

  // ── Child tables ──
  roomSnapshots    RoomSnapshot[]
  processSnapshots ProcessSnapshot[]
  creepRoles       CreepRoleSnapshot[]

  @@unique([serverId, tick, shard])
  @@index([serverId, recordedAt])
}

// ─── RoomSnapshot ────────────────────────────────────────────────────────────
// Per-room metrics for each tick snapshot.
model RoomSnapshot {
  id               Int          @id @default(autoincrement())
  tickSnapshotId   Int
  tickSnapshot     TickSnapshot @relation(fields: [tickSnapshotId], references: [id], onDelete: Cascade)
  roomName         String       // e.g. "E17S13"

  energyAvailable         Int    @default(0)
  energyCapacity          Int    @default(0)
  controllerLevel         Int    @default(0)
  controllerProgress      BigInt @default(0)
  controllerProgressTotal BigInt @default(0)
  storageEnergy           Int    @default(0)
  terminalEnergy          Int    @default(0)
  creepCount              Int    @default(0)
  hostileCount            Int    @default(0)

  @@index([tickSnapshotId])
}

// ─── ProcessSnapshot ─────────────────────────────────────────────────────────
// Per-process CPU usage for each tick snapshot.
model ProcessSnapshot {
  id             Int          @id @default(autoincrement())
  tickSnapshotId Int
  tickSnapshot   TickSnapshot @relation(fields: [tickSnapshotId], references: [id], onDelete: Cascade)
  processName    String       // e.g. "Hatchery", "MiningSite"
  cpuUsed        Float

  @@index([tickSnapshotId])
}

// ─── CreepRoleSnapshot ───────────────────────────────────────────────────────
// Per-role creep counts for each tick snapshot.
model CreepRoleSnapshot {
  id             Int          @id @default(autoincrement())
  tickSnapshotId Int
  tickSnapshot   TickSnapshot @relation(fields: [tickSnapshotId], references: [id], onDelete: Cascade)
  roleName       String       // e.g. "harvester", "hauler"
  count          Int

  @@index([tickSnapshotId])
}

// ─── FlightRecorderEntry ─────────────────────────────────────────────────────
// Events from the bot's FlightRecorder & console output.
// Segment 96 = console debug output, 98 = state transitions, 99 = errors.
model FlightRecorderEntry {
  id            Int      @id @default(autoincrement())
  tick          Int
  severity      String                     // "I", "W", "E"
  context       String                     // e.g. "Kernel", "ErrorMapper"
  message       String
  stackTrace    String?                    // Only for errors (segment 99)
  room          String?                    // Optional room tag
  correlationId String?                    // Optional cid
  segment       Int                        // 96, 98, or 99
  dedupHash     String   @unique          // MD5(serverId|tick|segment|context|message)
  recordedAt    DateTime @default(now())

  serverId String
  server   ScreepsServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, recordedAt])
  @@index([severity])
  @@index([segment])                       // For tiered retention queries
}

// ─── Severity Enum ───────────────────────────────────────────────────────────
enum Severity {
  INFO
  WARN
  ERROR
}

// ─── Log ─────────────────────────────────────────────────────────────────────
// Log entries with timestamp, message, and severity, linked to a server.
model Log {
  id        Int      @id @default(autoincrement())
  message   String
  severity  Severity @default(INFO)
  timestamp DateTime @default(now())

  serverId String
  server   ScreepsServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@index([timestamp])
  @@index([severity])
}

