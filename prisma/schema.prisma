// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User ────────────────────────────────────────────────────────────────────
// Stores login credentials for dashboard users.
model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  servers ScreepsServer[]
}

// ─── Screeps Server ──────────────────────────────────────────────────────────
// Represents a Screeps server instance (e.g. "World", "Season 8").
model ScreepsServer {
  id             String   @id @default(uuid())
  name           String   // e.g. "World", "Season 8"
  apiToken       String?  // Screeps API token / key for this server
  pushToken      String   @unique @default(uuid()) // Static token for push endpoints
  apiBaseUrl     String   @default("https://screeps.com") // Base URL for the Screeps API
  shard          String   @default("shard3") // Which shard to poll
  pollingEnabled Boolean  @default(false) // Whether background polling is enabled
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  stats                 Stat[]
  logs                  Log[]
  tickStats             TickStat[]
  flightRecorderEntries FlightRecorderEntry[]

  @@index([userId])
}

// ─── TickStat ────────────────────────────────────────────────────────────────
// Per-tick stats snapshot from StatsExporter (segment 97 or Memory.stats).
// Each row is one game tick, data is the full flat key-value snapshot.
model TickStat {
  id         Int      @id @default(autoincrement())
  tick       Int                        // Game tick number
  shard      String   @default("shard3")
  data       Json                       // Full flat key-value snapshot
  recordedAt DateTime @default(now())

  serverId String
  server   ScreepsServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, tick, shard])     // Prevent duplicate ingestion
  @@index([serverId, recordedAt])
}

// ─── FlightRecorderEntry ─────────────────────────────────────────────────────
// Events from the bot's FlightRecorder & console output.
// Segment 96 = console debug output, 98 = state transitions, 99 = errors.
model FlightRecorderEntry {
  id            Int      @id @default(autoincrement())
  tick          Int
  severity      String                     // "I", "W", "E"
  context       String                     // e.g. "Kernel", "ErrorMapper"
  message       String
  stackTrace    String?                    // Only for errors (segment 99)
  room          String?                    // Optional room tag
  correlationId String?                    // Optional cid
  segment       Int                        // 96, 98, or 99
  dedupHash     String   @unique          // MD5(serverId|tick|segment|context|message)
  recordedAt    DateTime @default(now())

  serverId String
  server   ScreepsServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, recordedAt])
  @@index([severity])
  @@index([segment])                       // For tiered retention queries
}

// ─── Stat ────────────────────────────────────────────────────────────────────
// Time-series data stored as JSON, linked to a specific server.
model Stat {
  id         Int      @id @default(autoincrement())
  data       Json     // Arbitrary time-series payload
  recordedAt DateTime @default(now())

  serverId String
  server   ScreepsServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@index([recordedAt])
}

// ─── Severity Enum ───────────────────────────────────────────────────────────
enum Severity {
  INFO
  WARN
  ERROR
}

// ─── Log ─────────────────────────────────────────────────────────────────────
// Log entries with timestamp, message, and severity, linked to a server.
model Log {
  id        Int      @id @default(autoincrement())
  message   String
  severity  Severity @default(INFO)
  timestamp DateTime @default(now())

  serverId String
  server   ScreepsServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@index([timestamp])
  @@index([severity])
}
